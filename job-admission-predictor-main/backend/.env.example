# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/job_admission_db?retryWrites=true&w=majority

# Flask Secret Key (Generate a random string for JWT)
SECRET_KEY=your_super_secret_jwt_key_change_this_in_production_12345

# Flask Environment
FLASK_ENV=development

# Port (optional, defaults to 5000)
PORT=5000
